{
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/evaluate/coming-from-temporal",
      "destination": "/docs/evaluate/coming-from/temporal",
      "permanent": true
    },
    {
      "source": "/evaluate/coming-from-dbos",
      "destination": "/docs/evaluate/coming-from/dbos",
      "permanent": true
    },
    {
      "source": "/get-started/new-project/ai-agent-loops",
      "destination": "/docs/get-started/examples/deep-research-agent",
      "permanent": true
    },
    {
      "source": "/get-started/new-project/:path*",
      "destination": "/docs/get-started/examples/:path*",
      "permanent": true
    },
    {
      "source": "/concepts/durable-promise",
      "destination": "https://www.distributed-async-await.io/specification/programming-model/durable-promise-specification",
      "permanent": true
    },
    {
      "source": "/get-started/project-templates/:path*",
      "destination": "/docs/get-started/examples/:path*",
      "permanent": true
    },
    {
      "source": "/operate/cli-reference/:path*",
      "destination": "/docs/get-started/cli-guide",
      "permanent": true
    },
    {
      "source": "/operate/errors",
      "destination": "/docs/debug/errors",
      "permanent": true
    },
    {
      "source": "/operate/troubleshooting",
      "destination": "/docs/debug/troubleshooting",
      "permanent": true
    },
    {
      "source": "/operate",
      "destination": "/docs/deploy",
      "permanent": true
    },
    {
      "source": "/operate/run-server",
      "destination": "/docs/deploy/run-server",
      "permanent": true
    },
    {
      "source": "/operate/security",
      "destination": "/docs/deploy/security",
      "permanent": true
    },
    {
      "source": "/operate/message-transports",
      "destination": "/docs/deploy/message-transports",
      "permanent": true
    },
    {
      "source": "/operate/serverless-workers",
      "destination": "/docs/deploy/serverless-workers",
      "permanent": true
    },
    {
      "source": "/operate/upgrade-server",
      "destination": "/docs/deploy/upgrade-server",
      "permanent": true
    },
    {
      "source": "/operate/production",
      "destination": "/docs/deploy",
      "permanent": true
    },
    {
      "source": "/operate/observe",
      "destination": "/docs/deploy",
      "permanent": true
    },
    {
      "source": "/operate/observe/logs",
      "destination": "/docs/deploy/logging",
      "permanent": true
    },
    {
      "source": "/operate/observe/metrics",
      "destination": "/docs/deploy/metrics",
      "permanent": true
    },
    {
      "source": "/operate/observe/traces",
      "destination": "/docs/deploy/tracing",
      "permanent": true
    },
    {
      "source": "/evaluate/:path*",
      "destination": "/docs/evaluate/:path*",
      "permanent": true
    },
    {
      "source": "/get-started/:path*",
      "destination": "/docs/get-started/:path*",
      "permanent": true
    },
    {
      "source": "/develop/:path*",
      "destination": "/docs/develop/:path*",
      "permanent": true
    },
    {
      "source": "/debug/:path*",
      "destination": "/docs/debug/:path*",
      "permanent": true
    },
    {
      "source": "/deploy/:path*",
      "destination": "/docs/deploy/:path*",
      "permanent": true
    },
    {
      "source": "/learn/:path*",
      "destination": "/docs/learn/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    }
  ]
}
