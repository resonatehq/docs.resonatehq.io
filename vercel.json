{
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/evaluate/coming-from-temporal",
      "destination": "/evaluate/coming-from/temporal",
      "permanent": true
    },
    {
      "source": "/evaluate/coming-from-dbos",
      "destination": "/evaluate/coming-from/dbos",
      "permanent": true
    },
    {
      "source": "/get-started/new-project/ai-agent-loops",
      "destination": "/get-started/examples/deep-research-agent",
      "permanent": true
    },
    {
      "source": "/get-started/new-project/:path*",
      "destination": "/get-started/examples/:path*",
      "permanent": true
    },
    {
      "source": "/concepts/durable-promise",
      "destination": "https://www.distributed-async-await.io/specification/programming-model/durable-promise-specification",
      "permanent": true
    },
    {
      "source": "/get-started/project-templates/:path*",
      "destination": "/get-started/examples/:path*",
      "permanent": true
    },
    {
      "source": "/learn/python-sdk/website-summarization-agent",
      "destination": "/get-started/examples",
      "permanent": true
    },
    {
      "source": "/learn/typescript-sdk/website-summarization-agent",
      "destination": "/get-started/examples",
      "permanent": true
    },
    {
      "source": "/learn/deployments/google-cloud-run",
      "destination": "/get-started/examples/durable-serverless-cloud-run-workers",
      "permanent": true
    },
    {
      "source": "/learn/deployments/digital-ocean-droplet",
      "destination": "/deploy/run-server",
      "permanent": true
    },
    {
      "source": "/learn/deployments/:path*",
      "destination": "/deploy",
      "permanent": true
    },
    {
      "source": "/learn/deployments",
      "destination": "/deploy",
      "permanent": true
    },
    {
      "source": "/learn/:path*",
      "destination": "/get-started/examples",
      "permanent": true
    },
    {
      "source": "/learn",
      "destination": "/get-started/examples",
      "permanent": true
    },
    {
      "source": "/operate/cli-reference/:path*",
      "destination": "/get-started/cli-guide",
      "permanent": true
    },
    {
      "source": "/operate/errors",
      "destination": "/debug/errors",
      "permanent": true
    },
    {
      "source": "/operate/troubleshooting",
      "destination": "/debug/troubleshooting",
      "permanent": true
    },
    {
      "source": "/operate",
      "destination": "/deploy",
      "permanent": true
    },
    {
      "source": "/operate/run-server",
      "destination": "/deploy/run-server",
      "permanent": true
    },
    {
      "source": "/operate/security",
      "destination": "/deploy/security",
      "permanent": true
    },
    {
      "source": "/operate/message-transports",
      "destination": "/deploy/message-transports",
      "permanent": true
    },
    {
      "source": "/operate/serverless-workers",
      "destination": "/deploy/serverless-workers",
      "permanent": true
    },
    {
      "source": "/operate/upgrade-server",
      "destination": "/deploy/upgrade-server",
      "permanent": true
    },
    {
      "source": "/operate/production",
      "destination": "/deploy",
      "permanent": true
    },
    {
      "source": "/operate/observe",
      "destination": "/deploy",
      "permanent": true
    },
    {
      "source": "/operate/observe/logs",
      "destination": "/deploy/logging",
      "permanent": true
    },
    {
      "source": "/operate/observe/metrics",
      "destination": "/deploy/metrics",
      "permanent": true
    },
    {
      "source": "/operate/observe/traces",
      "destination": "/deploy/tracing",
      "permanent": true
    },
    {
      "source": "/docs",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/docs/:path*",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    }
  ]
}
